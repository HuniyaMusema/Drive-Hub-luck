:{$PORT:5173} {
	root * /app/dist
	encode gzip

	# Cache static assets aggressively (they are content-hashed by Vite)
	@assets {
		path /assets/*
	}
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Do not cache index.html so the browser always fetches the latest shell
	header /index.html Cache-Control "no-cache, no-store, must-revalidate"

	file_server

	# SPA fallback: serve index.html for any path that does not match a file
	try_files {path} /index.html
}
