    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
