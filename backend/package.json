  "description": "Backend API for Drive-Hub-luck",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:backup": "pg_dump -U postgres -d car_platform_db -h localhost -p 5432 --clean --if-exists -f database/full_backup.sql",
    "db:restore": "psql -U postgres -d car_platform_db -h localhost -p 5432 -f database/full_backup.sql",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
